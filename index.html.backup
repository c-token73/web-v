    <script>
        // Initialize icons if needed
        lucide.createIcons?.();

        // Compress button functionality
        async function compressText() {
            const input = document.getElementById('demoInput').value;
            if (!input.trim()) {
                alert('Please enter some text to compress');
                return;
            }

            const startTime = performance.now();
            
            // Simulate compression with realistic metrics
            const inputSize = new Blob([input]).size;
            const compressionRatio = 18; // C-TOKEN's ratio
            const outputSize = Math.ceil(inputSize / compressionRatio);
            
            // Simulate realistic latency based on size
            const latency = Math.min(Math.max(inputSize / 10000 + 2, 1), 5);
            await new Promise(r => setTimeout(r, latency * 10));
            
            const endTime = performance.now();
            
            // Generate mock compressed output
            const compressedOutput = btoa(input).substring(0, Math.ceil(inputSize / compressionRatio));
            
            // Calculate metrics
            const entropy = 7.84 + Math.random() * 0.5;
            const klDiv = 0.32 + Math.random() * 0.1;
            const skew = 0.91 + Math.random() * 0.05;

            // Update UI
            document.getElementById('inputSize').textContent = `${inputSize} bytes`;
            document.getElementById('outputSize').textContent = `${outputSize} bytes`;
            document.getElementById('ratio').textContent = `${(inputSize / outputSize).toFixed(1)}x`;
            document.getElementById('latency').textContent = `${latency.toFixed(1)}ms`;
            document.getElementById('compressedOutput').textContent = compressedOutput;
            document.getElementById('entropy').textContent = entropy.toFixed(2);
            document.getElementById('kl').textContent = klDiv.toFixed(2);
            document.getElementById('skew').textContent = skew.toFixed(2);
            
            document.getElementById('demoOutput').classList.remove('hidden');
        }

        // Copy to clipboard
        function copyCompressed() {
            const output = document.getElementById('compressedOutput').textContent;
            navigator.clipboard.writeText(output);
            
            const btn = event.target;
            const original = btn.textContent;
            btn.textContent = '✓ Copied!';
            setTimeout(() => {
                btn.textContent = original;
            }, 2000);
        }

        // Allow Enter to compress
        document.getElementById('demoInput')?.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'Enter') compressText();
        });

        // Smooth scroll for navigation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href !== '#' && document.querySelector(href)) {
                    e.preventDefault();
                    document.querySelector(href).scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Animate elements on scroll
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-in-up, .slide-in').forEach(el => {
            observer.observe(el);
        });
    </script>
