let encoder = EncoderBuilder::new("log")
    .with_vocab("patterns.bin")
    .build()?;

let encoded = encoder.encode(
    "Error from 192.168.1.5"
)?;

println!("CR: {:.2}x", 
    encoded.compression_ratio);</code></pre>
