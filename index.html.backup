        <!-- POSITIONING / WHY NOW -->
        <section class="section-padding max-w-5xl mx-auto border-t border-gray-700/50">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-4xl font-bold gradient-text mb-6">Why Now?</h2>
                    <p class="text-gray-300 mb-6 leading-relaxed">
                        The LLM explosion has created a <span class="text-yellow-400 font-semibold">trillion-token consumption crisis</span>. 
                        Inference token costs are the dominant operating expense for AI services. <span class="text-yellow-400 font-semibold">Every 10% improvement in compression = 10% reduction in inference costs.</span>
                    </p>
                    <div class="space-y-4">
                        <div class="flex gap-4">
                            <div class="text-2xl flex-shrink-0">📊</div>
                            <div>
                                <div class="font-bold">$500B+ AI/LLM Market (2026)</div>
                                <p class="text-sm text-gray-400">Growing 3x YoY. 90% of cost is inference (token processing).</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="text-2xl flex-shrink-0">⚙️</div>
                            <div>
                                <div class="font-bold">No Semantic Compression Layer</div>
                                <p class="text-sm text-gray-400">Today: raw bytes → tokenizer → model. No domain-aware compression exists.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="text-2xl flex-shrink-0">🏢</div>
                            <div>
                                <div class="font-bold">Enterprise Compliance Need</div>
                                <p class="text-sm text-gray-400">Deterministic, auditable compression required for HIPAA/SOC2/SOX.</p>
                            </div>
