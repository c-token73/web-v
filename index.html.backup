                        <pre class="text-gray-100 text-xs overflow-auto"><code>from ctoken import Compressor

# Initialize with entropy model
comp = Compressor(mode="semantic")

# Process input text
result = comp.compress(
    text="Your large language model input...",
    adaptive=True,
    preserve_semantics=True
)

print(f"Compression: {result.ratio}x")
print(f"Latency: {result.latency_ms}ms")
print(f"Tokens: {result.output_tokens}")</code></pre>
